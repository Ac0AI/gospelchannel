{
  "name": "gospelmigration",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "GOSPEL_BUILD_OFFLINE=1 node -e \"const fs=require('fs'); fs.rmSync('.next',{recursive:true,force:true,maxRetries:5,retryDelay:200});\" && GOSPEL_BUILD_OFFLINE=1 next build",
    "cf:build": "GOSPEL_BUILD_OFFLINE=1 node -e \"const fs=require('fs'); for (const path of ['.next','.open-next']) fs.rmSync(path,{recursive:true,force:true,maxRetries:5,retryDelay:200});\" && GOSPEL_BUILD_OFFLINE=1 opennextjs-cloudflare build",
    "preview": "npm run cf:build && opennextjs-cloudflare preview",
    "deploy": "npm run cf:build && opennextjs-cloudflare deploy",
    "start": "next start",
    "lint": "eslint .",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx scripts/db-seed.ts",
    "export:supabase": "tsx scripts/export-supabase.ts",
    "import:supabase": "tsx scripts/import-supabase.ts",
    "setup": "bash scripts/setup-local.sh",
    "check:env": "bash scripts/check-env.sh",
    "smoke": "bash scripts/smoke-test.sh",
    "smoke:preview": "tsx scripts/preview-smoke.ts",
    "debug:claim-verify": "tsx scripts/debug-claim-verify.ts",
    "media:backfill": "node scripts/backfill-r2-media.mjs",
    "media:heroes": "node scripts/backfill-owned-hero-images.mjs",
    "check:data": "node scripts/validate-content.mjs",
    "churches:reconcile": "node scripts/reconcile-church-source-of-truth.mjs",
    "churches:check": "node scripts/reconcile-church-source-of-truth.mjs --check",
    "churches:normalize:europe-locations": "node scripts/normalize-europe-location-cities.mjs",
    "churches:fix:europe-location-outliers": "node scripts/fix-europe-location-outliers.mjs",
    "churches:audit": "node scripts/audit-source-of-truth.mjs",
    "tech:websites": "node scripts/detect-church-website-tech.mjs",
    "backfill:website-playlists": "node scripts/backfill-website-playlists.mjs",
    "descriptions:rewrite": "node scripts/rewrite-generated-church-descriptions.mjs",
    "backfill:social": "node scripts/backfill-social-fallbacks.mjs",
    "refresh:video-backlog": "node scripts/refresh-church-video-backlog.mjs",
    "profile:church-page": "node scripts/profile-church-page.mjs",
    "research": "node scripts/research-churches.mjs",
    "qa:churches": "node scripts/score-church-quality.mjs",
    "discover:global": "node scripts/discover-global-church-candidates.mjs",
    "import:europe": "node scripts/import-international-churches-eu.mjs",
    "import:curated:europe": "node scripts/import-curated-europe-leads.mjs",
    "import:osm:europe": "node scripts/import-osm-europe-churches.mjs",
    "intake:global": "node scripts/run-global-intake.mjs",
    "approve:churches": "node scripts/bulk-approve-churches.mjs",
    "match:playlists": "node scripts/match-approved-spotify-playlists.mjs",
    "enrich:socials:second-wave": "node scripts/enrich-socials-second-wave.mjs",
    "screen:candidates": "node scripts/screen-church-candidates.mjs",
    "discover:sweden": "node scripts/discover-sweden-church-playlists.mjs && tmp/spreadsheets/.venv/bin/python scripts/export-sweden-church-playlists.py",
    "discover:sweden:loop": "node scripts/run-sweden-playlist-harvest-loop.mjs",
    "enrich": "node scripts/enrich-churches.mjs"
  },
  "dependencies": {
    "@better-auth/cli": "^1.3.7",
    "@better-auth/drizzle-adapter": "^1.3.7",
    "@neondatabase/serverless": "^1.0.1",
    "@opennextjs/cloudflare": "^1.8.4",
    "@anthropic-ai/sdk": "^0.78.0",
    "@mendable/firecrawl-js": "^4.16.0",
    "@sindresorhus/is": "^7.2.0",
    "apify-client": "^2.22.2",
    "better-auth": "^1.3.7",
    "drizzle-orm": "^0.44.2",
    "next": "16.1.6",
    "posthog-js": "^1.363.1",
    "posthog-node": "^5.28.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.5",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "google-auth-library": "^10.6.1",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
